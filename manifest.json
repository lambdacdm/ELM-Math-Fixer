{
  "manifest_version": 3,
  "name": "ELM Math Fixer",
  "description": "Fixes common KaTeX rendering failures on ELM by rescuing math blocks damaged by Markdown parsing.",
  "version": "1.0.4",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://elm.edina.ac.uk/*"],
      "js": ["katex/katex.min.js", "katex/contrib/auto-render.min.js", "content.js"],
      "css": ["katex/katex.min.css"],
      "run_at": "document_idle"
    }
  ]
}
