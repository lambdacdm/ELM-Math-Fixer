{
  "manifest_version": 3,
  "name": "ELM Math Fixer",
  "description": "Unofficial, unaffiliated KaTeX fix for ELM (Univ. of Edinburgh). No data collected — all processing runs locally in your browser.",
  "version": "1.2.1",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://elm.edina.ac.uk/*"],
      "js": ["katex/katex.min.js", "katex/contrib/auto-render.min.js", "math-core.js", "math-repair.js", "prompts.js", "content.js", "runtime.js"],
      "css": ["katex/katex.min.css", "ui.css"],
      "run_at": "document_idle"
    }
  ]
}
